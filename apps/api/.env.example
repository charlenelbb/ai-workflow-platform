DATABASE_URL="postgresql://postgres:postgres@localhost:5436/postgres"
REDIS_URL="redis://localhost:6379"
# 百炼（默认）：千问 qwen3.5-plus
DASHSCOPE_API_KEY="sk-..."
# 可选，默认北京：https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# OpenAI（可选）
OPENAI_API_KEY="sk-..."
PORT=3001
# 创建 App ApiKey（POST /apps/:appId/api-keys）时使用，请求头 X-Admin-Secret 须与此一致（建议随机长字符串）
# ADMIN_API_SECRET=your-long-random-secret
# 发布工作流时是否自动生成一把 ApiKey 并仅在响应中返回（用于嵌入链接 ?api_key=）；需同时配置 ADMIN_API_SECRET。设为 false 可关闭
# PUBLISH_AUTO_EMBED_API_KEY=true
# 每 App+API Key 组合每分钟最多请求次数（内存限流，单实例有效；默认 120）
# APP_RUN_RATE_LIMIT_PER_MIN=120
# 同步执行耗时排查：设为 1 时打印 executeGraph 总耗时与各 AI 节点 LLM 调用耗时（日志量轻）
# LOG_EXEC_TIMING=1
